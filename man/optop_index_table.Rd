         remove_symbols = TRUE, 
         remove_numbers = TRUE) \%>\% 
  tokens_tolower() \%>\% 
  tokens_remove(stopwords())
  
# Create the document-feature-matrix
mydfm <- dfm(toks)

# Estimate topic models via VEM
VEM_models <- lapply(
  K_grid, function(k) {
    topicmodels::LDA(x = mydfm, k = k)
  }
)

# 1) Quick run: compute partition/baseline internally
